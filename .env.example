MYSQL_DATABASE=berufoods
MYSQL_USER=sqluser
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root

MERCURE_JWT_KEY="!ChangeThisToAStrongSecretKey!" # Used by Mercure service in docker-compose.yml
MERCURE_JWT_SECRET="!ChangeThisToTheSameStrongSecretKey!" # Used by Symfony MercureBundle in mercure.yaml
MERCURE_CORS_ALLOWED_ORIGINS="*" # Your frontend URL, backend URL for dev
MERCURE_URL="http://mercure/.well-known/mercure" # Internal URL for Symfony to publish
MERCURE_PUBLIC_URL="https://localhost/.well-known/mercure" # Public URL for clients