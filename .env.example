# ==============================================
# BeruFoods Environment Configuration Example
# ==============================================
# Copy this file to .env and update the values according to your environment

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# MySQL database configuration for the application
MYSQL_DATABASE=berufoods
MYSQL_USER=sqluser
MYSQL_PASSWORD=password
MYSQL_ROOT_PASSWORD=root

# ==============================================
# MERCURE REAL-TIME NOTIFICATIONS
# ==============================================
# Mercure configuration for Server-Sent Events (SSE) real-time notifications
# 
# IMPORTANT: Use the same strong secret for both Mercure service and Symfony backend
# In production, generate a secure random string (minimum 32 characters)
MERCURE_JWT_SECRET="!ChangeThisToAStrongSecretKey!" # Used by both Mercure service and Symfony backend

# Frontend URLs that are allowed to connect to Mercure (CORS configuration)
# Add your frontend URLs separated by spaces
# For development: include both HTTPS (for production) and HTTP (for local dev)
MERCURE_CORS_ALLOWED_ORIGINS="https://localhost http://localhost:5173" # Your frontend URLs for dev

# Internal URL used by Symfony backend to publish notifications to Mercure hub
# This should point to the Mercure service within the Docker network
MERCURE_URL="http://mercure/.well-known/mercure" # Internal URL for Symfony to publish

# Public URL used by frontend clients to subscribe to Mercure notifications
# This should be accessible from browsers and typically goes through a reverse proxy
MERCURE_PUBLIC_URL="https://localhost/.well-known/mercure" # Public URL for clients

# ==============================================
# DEVELOPMENT NOTES
# ==============================================
# 1. The MERCURE_JWT_SECRET must be the same across all services
# 2. MERCURE_URL uses the Docker service name "mercure" for internal communication
# 3. MERCURE_PUBLIC_URL uses "localhost" as it goes through the Nginx proxy
# 4. For production, ensure all URLs use HTTPS and valid certificates
# 5. Update MERCURE_CORS_ALLOWED_ORIGINS to include your production frontend URL